# =============================================================================
# Trading Journal — root .env.example
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit a .env file with real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL service (docker-compose db service)
# ---------------------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=trading_journal

# ---------------------------------------------------------------------------
# Backend — database connection strings
# DATABASE_URL      : used by the application at runtime (may be pooled).
# DIRECT_DATABASE_URL : bypasses any connection pooler; used by Alembic
#                      migrations. Leave blank to fall back to DATABASE_URL.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@db:5432/trading_journal
DIRECT_DATABASE_URL=

# ---------------------------------------------------------------------------
# Backend — authentication & security
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Backend — CORS
# Comma-separated list of allowed origins.
# Example for production: https://myapp.example.com
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Backend — OpenTelemetry
# ---------------------------------------------------------------------------
OTEL_SERVICE_NAME=trading-journal-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# URL that the Next.js server uses to proxy /api/* requests to the backend.
# In docker-compose the backend is reachable as http://backend:8000.
# For local dev without compose use http://127.0.0.1:8000.
NEXT_PUBLIC_API_URL=http://backend:8000

# ---------------------------------------------------------------------------
# Interactive Brokers Gateway
# ---------------------------------------------------------------------------
TWS_USERID=
TWS_PASSWORD=
TRADING_MODE=paper
READ_ONLY_API=no
TWOFA_TIMEOUT_ACTION=restart
# Time is interpreted in the TIME_ZONE specified below; 12-hour format (e.g. "11:59 PM")
AUTO_RESTART_TIME="11:59 PM"
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
TIME_ZONE=America/New_York

# ---------------------------------------------------------------------------
# Backend admin/migration scripts
# ---------------------------------------------------------------------------
# Base URL for the running backend instance (used by scripts/).
BACKEND_URL=http://localhost:8000
