# Copy to .env and fill. NEVER commit .env. See docs/design-hosting/operations/secrets-and-env-vars.md.

# =============================================================================
# FRONTEND — Next.js (🟢 Public — safe in browser bundle; NEXT_PUBLIC_ prefix required)
# =============================================================================

# Base URL of the FastAPI backend.
# Production Vercel deployments MUST set this to a public backend URL; localhost/private IPs are rejected.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project REST + Auth endpoint (from `supabase status` or Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key — browser-safe because RLS limits access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Canonical app URL for Supabase auth redirects (e.g. http://localhost:3000 locally)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# BACKEND — FastAPI Python worker (🔴 Server-only; never add NEXT_PUBLIC_ prefix)
# =============================================================================

# Full PostgreSQL connection string for legacy local-dev compose (includes credentials — treat as secret)
DATABASE_URL=postgresql://user:password@localhost:5432/trading-journal

# Supabase Postgres or pooler URL for docker-compose.backend.yml.
# Include sslmode=require when using Supabase direct Postgres.
DIRECT_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase project URL for backend JWT/JWKS verification.
SUPABASE_URL=https://zvbwgxdgxwgduhhzdwjj.supabase.co

# Browser origins allowed to call FastAPI. Supports comma-separated exact origins and limited wildcards.
BACKEND_CORS_ORIGINS=http://localhost:3000,https://trading-journal-cohenjos-projects.vercel.app,https://*.vercel.app

# HMAC-SHA256 signing key for internal JWT tokens — rotate every 90 days
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-here

# JWT token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase service-role key — NEVER add NEXT_PUBLIC_ prefix — bypasses RLS entirely
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Supabase JWT secret — only needed if doing manual JWT verification server-side
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# =============================================================================
# BACKEND — IB Gateway connection
# =============================================================================

# IB Gateway host (default: 127.0.0.1 for local Docker)
IB_HOST=127.0.0.1

# IB Gateway port: 4001 = live, 4002 = paper
IB_PORT=4002

# IB client connection ID (must be unique per concurrent connection)
IB_CLIENT_ID=2

# =============================================================================
# DOCKER COMPOSE — IB Gateway container (🔴 Broker credentials)
# =============================================================================

# Interactive Brokers account username
TWS_USERID=your-ib-username-here

# Interactive Brokers account password
TWS_PASSWORD=your-ib-password-here

# Trading mode: paper (safe default) or live
TRADING_MODE=paper

# Block order submission via API: yes = read-only, no = allow orders
READ_ONLY_API=no

# Action on 2FA timeout: restart or exit
TWOFA_TIMEOUT_ACTION=restart

# Daily automatic gateway restart time
AUTO_RESTART_TIME="11:59 PM"

# Auto-relogin after 2FA timeout: yes or no
RELOGIN_AFTER_TWOFA_TIMEOUT=yes

# Gateway timezone (TZ database name)
TIME_ZONE=Asia/Jerusalem

# =============================================================================
# LOCAL DEV — Supabase CLI (🔴 Never commit; set in shell or .env)
# =============================================================================

# Supabase personal access token for `supabase link` / `supabase db push`
# Generate at: Supabase dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token-here

# Direct Postgres URL to local Supabase stack (from `supabase status`)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =============================================================================
# GITHUB ACTIONS — set these in repo Settings → Secrets / Variables, NOT here
# =============================================================================

# GH Actions secret: production Supabase database URL with credentials
# SUPABASE_PROD_DB_URL=postgresql://postgres:your-prod-pass@db.your-project-ref.supabase.co:5432/postgres

# GH Actions secret: AGE encryption public key for backup archives
# AGE_PUBLIC_KEY=age1your-public-key-here

# GH Actions secret: GitHub PAT for squad issue-assign workflow
# COPILOT_ASSIGN_TOKEN=github_pat_your-token-here

# GH Actions var (non-secret): Supabase project reference IDs
# SUPABASE_DEV_REF=your-dev-project-ref
# SUPABASE_PREVIEW_REF=your-preview-project-ref
# SUPABASE_PROD_REF=your-prod-project-ref
