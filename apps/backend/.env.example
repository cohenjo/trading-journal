# Database — PostgreSQL connection string used by the application at runtime.
# For pooled deployments (PgBouncer, Supabase pooler, etc.) set DATABASE_URL
# to the pooled URL and DIRECT_DATABASE_URL to the direct (non-pooled) URL.
DATABASE_URL=postgresql://user:password@localhost/trading_journal
DIRECT_DATABASE_URL=

# PostgreSQL service credentials (used by docker-compose to initialize the DB).
# These must match the credentials embedded in DATABASE_URL above.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=trading_journal

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins.
# Example for production: https://myapp.example.com,https://www.myapp.example.com
CORS_ORIGINS=http://localhost:3000

# OpenTelemetry
OTEL_SERVICE_NAME=trading-journal-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
